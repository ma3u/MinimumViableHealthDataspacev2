# =============================================================================
# IdentityHub Environment Configuration
# =============================================================================
# Docker Compose equivalent of K8s identityhub-config ConfigMap.
# Adapt K8s internal DNS (*.edc-v.svc.cluster.local) to docker-compose service names.
# =============================================================================

# Hostname
edc.hostname=identityhub

# Credential revocation (note: the typo "credentia" is in the JAD upstream source)
edc.iam.credentia.revocation.mimetype=application/json

# DID
edc.iam.did.web.use.https=false

# Identity Hub public key
edc.ih.iam.publickey.alias=publickey-alias

# Web ports
web.http.port=7080
web.http.path=/api
web.http.identity.port=7081
web.http.identity.path=/api/identity
web.http.identity.auth.key=password
web.http.credentials.port=7082
web.http.credentials.path=/api/credentials
web.http.did.port=7083
web.http.did.path=/
web.http.sts.port=7084
web.http.sts.path=/api/sts

# Database
edc.datasource.default.url=jdbc:postgresql://postgres:5432/identityhub
edc.datasource.default.user=ih
edc.datasource.default.password=ih
edc.sql.schema.autocreate=true

# Access token validation
edc.iam.accesstoken.jti.validation=true

# Credential renewal grace period (3600*24 = 1 day)
edc.iam.credential.renewal.graceperiod=86400

# Vault
edc.vault.hashicorp.url=http://vault:8200
edc.vault.hashicorp.token=root

# Encryption
edc.encryption.aes.key.alias=aes-key-alias

# OAuth2 / Keycloak
# issuer must match KC_HOSTNAME (iss claim in tokens is always http://localhost:8080)
edc.iam.oauth2.issuer=http://localhost:8080/realms/edcv
edc.iam.oauth2.jwks.url=http://keycloak:8080/realms/edcv/protocol/openid-connect/certs
