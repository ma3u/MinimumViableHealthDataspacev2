{
  "name": "PatientIdentityCredential",
  "protocol": "oid4vc",
  "description": "EHDS patient identity + secondary-use consent, issued as an SD-JWT VC to the EUDI wallet (OpenID4VCI).",
  "attributes": {
    "include.in.token.scope": "true",
    "display.on.consent.screen": "true",
    "vc.format": "dc+sd-jwt",
    "vc.verifiable_credential_type": "https://ehds.mabu.red/credentials/patient-identity",
    "vc.credential_signing_alg": "ES256",
    "vc.credential_build_config.token_jws_type": "dc+sd-jwt",
    "vc.expiry_in_seconds": "604800",
    "vc.display": "[{\"name\":\"EHDS Patient Identity\",\"locale\":\"en\",\"background_color\":\"#0b3d66\",\"text_color\":\"#ffffff\"}]"
  },
  "protocolMappers": [
    {
      "name": "given_name",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-user-attribute-mapper",
      "config": {
        "claim.name": "given_name",
        "userAttribute": "firstName",
        "vc.display": "[{\"name\":\"Given name\",\"locale\":\"en\"}]"
      }
    },
    {
      "name": "family_name",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-user-attribute-mapper",
      "config": {
        "claim.name": "family_name",
        "userAttribute": "lastName",
        "vc.display": "[{\"name\":\"Family name\",\"locale\":\"en\"}]"
      }
    },
    {
      "name": "patient_pseudonym",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-user-attribute-mapper",
      "config": {
        "claim.name": "patient_pseudonym",
        "userAttribute": "pseudonym",
        "vc.display": "[{\"name\":\"Patient pseudonym\",\"locale\":\"en\"}]"
      }
    },
    {
      "name": "consent_purpose",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-static-claim-mapper",
      "config": {
        "claim.name": "consent_purpose",
        "staticValue": "secondary-use/research"
      }
    },
    {
      "name": "consent_scope",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-static-claim-mapper",
      "config": {
        "claim.name": "consent_scope",
        "staticValue": "drug-repurposing-study"
      }
    },
    {
      "name": "ehds_role",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-static-claim-mapper",
      "config": {
        "claim.name": "role",
        "staticValue": "PATIENT"
      }
    },
    {
      "name": "issued_at",
      "protocol": "oid4vc",
      "protocolMapper": "oid4vc-issued-at-time-claim-mapper",
      "config": {
        "claim.name": "iat",
        "truncateToTimeUnit": "SECONDS"
      }
    }
  ]
}
