    "edc:type": "FhirCohort",
    "edc:version": "1.0",
    "dct:conformsTo": "http://hl7.org/fhir/R4",
    "healthdcatap:datasetType": "SyntheticData",
    "healthdcatap:healthCategory": [
      "patient-summary",
      "ePrescription",
      "laboratory-results"
    ],
    "healthdcatap:numberOfRecords": 167,
    "healthdcatap:numberOfUniqueIndividuals": 167,
    "healthdcatap:minTypicalAge": 0,
    "healthdcatap:maxTypicalAge": 105
  },
  "edc:dataAddress": {
    "@type": "edc:DataAddress",
    "edc:type": "HttpData",
    "edc:baseUrl": "http://neo4j-proxy:9090/fhir/Bundle",
    "edc:proxyMethod": true,
    "edc:proxyBody": true,
    "edc:proxyPath": true,
    "edc:contentType": "application/fhir+json"
  }
