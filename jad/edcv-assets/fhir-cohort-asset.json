  "edc:properties": {
    "edc:name": "Synthea FHIR R4 Patient Cohort",
    "edc:description": "Synthetic longitudinal patient records (167 patients, encounters, conditions, medications, procedures, observations) generated by Synthea, loaded as FHIR R4 resources in the Neo4j health knowledge graph. Accessible via parameterized cohort queries returning FHIR Bundle JSON.",
