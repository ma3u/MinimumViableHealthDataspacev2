# =============================================================================
# IssuerService Environment Configuration
# =============================================================================
# Docker Compose equivalent of K8s issuerservice-config ConfigMap.
# =============================================================================

# Hostname
edc.hostname=issuerservice

# Web ports
web.http.port=10010
web.http.path=/api
web.http.sts.port=10011
web.http.sts.path=/api/sts
web.http.issuance.port=10012
web.http.issuance.path=/api/issuance
web.http.issueradmin.port=10013
web.http.issueradmin.path=/api/admin
web.http.identity.port=10015
web.http.identity.path=/api/identity
web.http.did.port=10016
web.http.did.path=/
web.http.statuslist.port=9999
web.http.statuslist.path=/api/statuslist

# Database
edc.datasource.default.url=jdbc:postgresql://postgres:5432/issuerservice
edc.datasource.default.user=issuer
edc.datasource.default.password=issuer
edc.sql.schema.autocreate=true

# Vault
edc.vault.hashicorp.url=http://vault:8200
edc.vault.hashicorp.token=root

# DID
edc.iam.did.web.use.https=false
edc.participant.id=did:web:issuerservice%3A10016:issuer

# OAuth2 / Keycloak
edc.iam.oauth2.issuer=http://keycloak:8080/realms/edcv
edc.iam.oauth2.jwks.url=http://keycloak:8080/realms/edcv/protocol/openid-connect/certs

# Encryption
edc.encryption.aes.key.alias=aes-key-alias
