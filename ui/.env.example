# =============================================================================
# Health Dataspace UI – Environment Variables
# =============================================================================
# Copy to .env.local and adjust values for your environment.
# .env.local is excluded from git (see .gitignore).
# =============================================================================

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=healthdataspace

# Keycloak SSO (Phase 2c)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-a-random-32-char-secret>

KEYCLOAK_CLIENT_ID=health-dataspace-ui
KEYCLOAK_CLIENT_SECRET=health-dataspace-ui-secret

# Server-side: OIDC discovery + token exchange
# Use localhost when running outside Docker, keycloak:8080 when inside Docker
KEYCLOAK_ISSUER=http://localhost:8080/realms/edcv

# Browser-side: authorization redirect (always localhost for local dev)
KEYCLOAK_PUBLIC_URL=http://localhost:8080/realms/edcv

# Client-side env vars (NEXT_PUBLIC_ prefix – embedded in browser bundle)
NEXT_PUBLIC_KEYCLOAK_PUBLIC_URL=http://localhost:8080/realms/edcv
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=health-dataspace-ui

# JAD / CFM service URLs – localhost port mappings for local dev (npm run dev)
# These override Docker-internal hostnames in src/lib/edc/client.ts
# Port mappings are defined in docker-compose.jad.yml
EDC_MANAGEMENT_URL=http://localhost:11003/api/mgmt
EDC_IDENTITY_URL=http://localhost:11005/api/identity
EDC_ISSUER_URL=http://localhost:10013/api/admin
EDC_TENANT_URL=http://localhost:11006/api
EDC_PROVISION_URL=http://localhost:11007/api

# Keycloak internal URL for server-side client-credentials token exchange
KEYCLOAK_INTERNAL_URL=http://localhost:8080

# Service account credentials for server-side API calls (client_credentials grant)
EDC_SERVICE_CLIENT_ID=admin
EDC_SERVICE_CLIENT_SECRET=edc-v-admin-secret
